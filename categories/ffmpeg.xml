<?xml-stylesheet type="text/xsl" href="../assets/xml/rss.xsl" media="all"?><rss version="2.0" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>NULL (关于文章 FFmpeg)</title><link>/</link><description></description><atom:link href="/categories/ffmpeg.xml" rel="self" type="application/rss+xml"></atom:link><language>zh_cn</language><copyright>Contents © 2018 &lt;a href="mailto:garfileo@gmail.com"&gt;Garfileo&lt;/a&gt; </copyright><lastBuildDate>Wed, 14 Nov 2018 09:33:26 GMT</lastBuildDate><generator>Nikola (getnikola.com)</generator><docs>http://blogs.law.harvard.edu/tech/rss</docs><item><title>FFmpeg 笔记</title><link>/posts/ffmpeg.html</link><dc:creator>Garfileo</dc:creator><description>&lt;div&gt;&lt;h2&gt;去水印&lt;/h2&gt;
&lt;pre class="code literal-block"&gt;&lt;span&gt;&lt;/span&gt;&lt;span class="gp"&gt;$&lt;/span&gt; ffmpeg -threads &lt;span class="m"&gt;4&lt;/span&gt; -i input.mp4 &lt;span class="se"&gt;\&lt;/span&gt;
    -filter_complex &lt;span class="s2"&gt;"delogo=x=5:y=320:w=110:h=75, delogo=x=625:y=350:w=90:h=45"&lt;/span&gt; &lt;span class="se"&gt;\&lt;/span&gt;
    -qscale &lt;span class="m"&gt;2&lt;/span&gt;.5 output.mp4
&lt;/pre&gt;


&lt;p&gt;&lt;code&gt;qscale&lt;/code&gt; 用于设定输出视频的画面质量，取值范围为 [0.01,255]，此值越小，画面质量越好。&lt;/p&gt;
&lt;p&gt;&lt;code&gt;delogo&lt;/code&gt; 参数用于设定过滤水印的矩形区域，&lt;code&gt;x&lt;/code&gt; 和 &lt;code&gt;y&lt;/code&gt; 为矩形的左上角坐标，&lt;code&gt;w&lt;/code&gt; 和 &lt;code&gt;h&lt;/code&gt; 分别为矩形的宽度和高度。可以通过视频播放软件提供的截屏功能，再用 GIMP 对所截图像确定这个矩形范围。&lt;/p&gt;
&lt;p&gt;使用 ffplay 可预览硬盘中的水印过滤区域：&lt;/p&gt;
&lt;pre class="code literal-block"&gt;&lt;span&gt;&lt;/span&gt;&lt;span class="gp"&gt;$&lt;/span&gt; ffplay -i input.mp4 &lt;span class="se"&gt;\&lt;/span&gt;
  -vf &lt;span class="s2"&gt;"delogo=x=5:y=320:w=110:h=75:show=1, delogo=x=625:y=350:w=90:h=45:show=1"&lt;/span&gt;
&lt;/pre&gt;


&lt;h2&gt;时间裁剪&lt;/h2&gt;
&lt;p&gt;下面这个脚本，可以按给定时间点去除当前目录内所有视频的片头：&lt;/p&gt;
&lt;pre class="code literal-block"&gt;&lt;span&gt;&lt;/span&gt;&lt;span class="ch"&gt;#!/bin/bash&lt;/span&gt;

clip_all&lt;span class="o"&gt;()&lt;/span&gt; &lt;span class="o"&gt;{&lt;/span&gt;
    &lt;span class="k"&gt;for&lt;/span&gt; i in ./*
    &lt;span class="k"&gt;do&lt;/span&gt;
        &lt;span class="k"&gt;if&lt;/span&gt; &lt;span class="o"&gt;[&lt;/span&gt; -d &lt;span class="nv"&gt;$i&lt;/span&gt; &lt;span class="o"&gt;]&lt;/span&gt;
        &lt;span class="k"&gt;then&lt;/span&gt;
            &lt;span class="nb"&gt;cd&lt;/span&gt; &lt;span class="nv"&gt;$i&lt;/span&gt;
            clip_all &lt;span class="nv"&gt;$1&lt;/span&gt;
        &lt;span class="k"&gt;else&lt;/span&gt;
            ffmpeg -ss &lt;span class="nv"&gt;$1&lt;/span&gt; -accurate_seek -i &lt;span class="nv"&gt;$i&lt;/span&gt; &lt;span class="se"&gt;\&lt;/span&gt;
                   -vcodec copy -acodec copy -avoid_negative_ts &lt;span class="m"&gt;1&lt;/span&gt; new-&lt;span class="si"&gt;${&lt;/span&gt;&lt;span class="nv"&gt;i&lt;/span&gt;&lt;span class="si"&gt;}&lt;/span&gt;
            rm &lt;span class="nv"&gt;$i&lt;/span&gt;
            mv new-&lt;span class="si"&gt;${&lt;/span&gt;&lt;span class="nv"&gt;i&lt;/span&gt;&lt;span class="si"&gt;}&lt;/span&gt; &lt;span class="nv"&gt;$i&lt;/span&gt;
        &lt;span class="k"&gt;fi&lt;/span&gt;
    &lt;span class="k"&gt;done&lt;/span&gt;
&lt;span class="o"&gt;}&lt;/span&gt;

clip_all &lt;span class="nv"&gt;$1&lt;/span&gt;
&lt;/pre&gt;&lt;/div&gt;</description><category>FFmpeg</category><guid>/posts/ffmpeg.html</guid><pubDate>Wed, 14 Nov 2018 02:34:36 GMT</pubDate></item></channel></rss>